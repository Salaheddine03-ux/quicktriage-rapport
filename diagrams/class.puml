@startuml class
skinparam dpi 150
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam linetype ortho
skinparam ArrowColor #34495E
skinparam class {
  BackgroundColor #FBFCFC
  BorderColor #1F618D
  ArrowColor #34495E
  AttributeFontColor #1B2631
}
hide circle

' ====================== UTILISATEURS ======================
abstract class Utilisateur {
  - idUtilisateur : Long
  - nom : String
  - prenom : String
  - email : String
  - motDePasse : String
  - role : String
  + seConnecter() : boolean
  + seDeconnecter() : void
}

class StaffMedical {
  - matricule : String
  - service : String
  + remplirFormulaire(p : Patient) : EvaluationTriage
  + lancerPrediction(e : EvaluationTriage) : PredictionResult
  + consulterFileAttente() : List<EvaluationTriage>
  + consulterHistorique() : List<EvaluationTriage>
}

class Medecin {
  - specialite : String
  + consulterResultat(e : EvaluationTriage) : PredictionResult
  + validerDecision(e : EvaluationTriage) : void
  + rectifierDecision(e : EvaluationTriage, c : KtasClass) : void
  + ajouterCommentaire(e : EvaluationTriage, txt : String) : void
  + prendreDecisionFinale(e : EvaluationTriage) : void
}

class Administrateur {
  + gererStaff(u : StaffMedical) : void
  + gererMedecins(m : Medecin) : void
  + gererPatients(p : Patient) : void
  + consulterStatistiques() : Statistiques
  + consulterHistoriqueSysteme() : List<Log>
}

Utilisateur <|-- StaffMedical
Utilisateur <|-- Medecin
Utilisateur <|-- Administrateur

' ====================== DOMAINE METIER ======================
class Patient {
  - idPatient : Long
  - nom : String
  - prenom : String
  - age : int
  - sexe : char
  - numeroDossier : String
  + getDossier() : String
}

class EvaluationTriage {
  - idEvaluation : Long
  - dateHeure : DateTime
  - sbp : float
  - dbp : float
  - hr : float
  - rr : float
  - bt : float
  - saturation : float
  - nrsPain : int
  - etatMental : int
  - statut : String
  - decisionFinale : KtasClass
  - commentaireMedical : String
  + getFeatures() : float[]
}

class PredictionResult {
  - idResultat : Long
  - classeKTAS : KtasClass
  - scoreConfiance : float
  - probabilites : Map<KtasClass, Float>
  - isCritical : boolean
  - modelVersion : String
  - dateGeneration : DateTime
}

enum KtasClass {
  CRITIQUE
  URGENT
  NON_URGENT
}

Patient "1" --o "*" EvaluationTriage : concerne
StaffMedical "1" --> "*" EvaluationTriage : réalise
Medecin "1" --> "*" EvaluationTriage : valide
EvaluationTriage "1" *-- "1" PredictionResult : produit
EvaluationTriage --> KtasClass
PredictionResult --> KtasClass

' ====================== COUCHE BACKEND J2EE ======================
interface ApiRest {
  + recevoirDonnees(req : TriageRequest) : Response
  + preparerDonnees(req : TriageRequest) : float[]
  + appelerModele(features : float[]) : PredictionResult
  + retournerResultat(res : PredictionResult) : Response
}

class TriageController {
  + predict(req : TriageRequest) : Response
  + getFileAttente() : Response
  + confirmDecision(req : DecisionRequest) : Response
}

class TriageService {
  + buildFeatures(e : EvaluationTriage) : float[]
  + normalize(f : float[]) : float[]
  + applyThreshold(proba : float[]) : PredictionResult
  + predire(e : EvaluationTriage) : PredictionResult
}

class ModeleML {
  - session : OrtSession
  - seuilCritique : float
  + recevoirFeatures(f : float[]) : void
  + predire() : float[]
  + retournerScore() : PredictionResult
}

TriageController ..|> ApiRest
TriageController "1" --> "1" TriageService : délègue
TriageService "1" --> "1" ModeleML : appelle
TriageService ..> EvaluationTriage : exploite
TriageService ..> PredictionResult : crée
@enduml
