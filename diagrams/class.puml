@startuml class
skinparam dpi 150
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam linetype ortho
skinparam ArrowColor #34495E
skinparam class {
  BackgroundColor #FBFCFC
  BorderColor #1F618D
  ArrowColor #34495E
  AttributeFontColor #1B2631
}
hide circle

' ====================== UTILISATEURS ======================
abstract class Utilisateur {
  - idUtilisateur : Long
  - nom : String
  - prenom : String
  - email : String
  - motDePasse : String
  - role : String
  + seConnecter() : boolean
  + seDeconnecter() : void
}

class StaffMedical {
  - matricule : String
  - service : String
  + remplirFormulaire() : EvaluationTriage
  + lancerPrediction() : PredictionResult
  + consulterFileAttente() : List<EvaluationTriage>
  + consulterHistoriquePatients() : List<EvaluationTriage>
}

class Medecin {
  - specialite : String
  + consulterResultat() : PredictionResult
  + consulterDonneesPatient() : Patient
  + validerDecision() : void
  + rectifierDecision() : void
  + ajouterCommentaire() : void
  + prendreDecisionFinale() : void
}

class Administrateur {
  + gererStaff() : void
  + gererMedecins() : void
  + gererPatients() : void
  + consulterStatistiques() : Statistique
  + consulterHistoriquesSysteme() : void
}

Utilisateur <|-- StaffMedical
Utilisateur <|-- Medecin
Utilisateur <|-- Administrateur

' ====================== DOMAINE METIER ======================
class Patient {
  - idPatient : Long
  - nom : String
  - prenom : String
  - age : int
  - sexe : String
  - numeroDossier : String
  + getDossier() : String
}

class EvaluationTriage {
  - idEvaluation : Long
  - dateHeure : DateTime
  - sbp : float
  - dbp : float
  - hr : float
  - rr : float
  - bt : float
  - saturation : float
  - nrsPain : int
  - etatMental : int
  - statut : String
  - decisionFinale : KtasClass
  - commentaireMedical : String
  + getFeatures() : float[]
}

class PredictionResult {
  - idResultat : Long
  - classeKTAS : KtasClass
  - scoreConfiance : float
  - isCritical : boolean
  - dateGeneration : DateTime
}

enum KtasClass {
  CRITIQUE
  URGENT
  NON_URGENT
}

' ====================== COUCHE APPLICATIVE ======================
class TriageController {
  + predict() : PredictionResult
  + getFileAttente() : List<EvaluationTriage>
  + confirmerDecision() : void
}

class TriageService {
  + buildFeatures() : float[]
  + normaliser() : float[]
  + appliquerSeuil() : PredictionResult
  + predire() : PredictionResult
  + enregistrerDecisionFinale() : void
}

class ServiceML {
  + recevoirFeatures() : void
  + predire() : float[]
  + retournerScore() : PredictionResult
}

class Statistique {
  - totalPatients : int
  - casCritiques : int
  - patientsEnAttente : int
  - repartitionKTAS : Map
  + calculerStatistiques() : void
}

' ====================== RELATIONS ======================
Patient "1" --o "*" EvaluationTriage : concerne
StaffMedical "1" --> "*" EvaluationTriage : réalise
Medecin "1" --> "*" EvaluationTriage : valide / rectifie
EvaluationTriage "1" *-- "1" PredictionResult : produit
EvaluationTriage --> KtasClass
PredictionResult --> KtasClass

TriageController "1" --> "1" TriageService : utilise
TriageService "1" --> "1" ServiceML : utilise
TriageService ..> EvaluationTriage : exploite
TriageService ..> PredictionResult : crée

Administrateur "1" --> "*" Utilisateur : gère
Administrateur "1" --> "*" Patient : gère
Administrateur "1" --> "1" Statistique : consulte
@enduml
