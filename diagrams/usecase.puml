@startuml usecase
left to right direction
skinparam dpi 150
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam ArrowColor #34495E
skinparam usecase {
  BackgroundColor #EAF2F8
  BorderColor #2471A3
  FontColor #1B2631
}
skinparam rectangle {
  BorderColor #1F618D
  BackgroundColor #FBFCFC
}
skinparam actor {
  BackgroundColor #D6EAF8
  BorderColor #1F618D
}

actor "Staff médical\n(Infirmier)" as Staff
actor "Médecin" as Doc
actor "Administrateur" as Admin
actor "API REST J2EE" as Api
actor "Modèle ML\n(XGBoost / ONNX)" as ML

rectangle "Système QuickTriage" {
  usecase "S'authentifier" as UC_Login
  usecase "Saisir les données\ndu patient" as UC_Data
  usecase "Remplir le formulaire\nde triage" as UC_Form
  usecase "Lancer la prédiction\nKTAS" as UC_Predict
  usecase "Consulter le\nrésultat initial" as UC_Result
  usecase "Consulter la\nfile d'attente" as UC_Queue
  usecase "Consulter l'historique\ndes patients" as UC_Hist
  usecase "Consulter les données\ndétaillées du patient" as UC_Detail
  usecase "Valider la décision" as UC_Validate
  usecase "Rectifier la décision" as UC_Rectify
  usecase "Ajouter un\ncommentaire médical" as UC_Comment
  usecase "Prendre la\ndécision finale" as UC_Final
  usecase "Gérer les comptes\ndu staff médical" as UC_MgStaff
  usecase "Gérer les médecins" as UC_MgDoc
  usecase "Gérer les patients" as UC_MgPat
  usecase "Consulter les\nstatistiques" as UC_Stats
  usecase "Consulter les\nhistoriques système" as UC_SysHist
}

' --- Staff médical ---
Staff --> UC_Login
Staff --> UC_Form
Staff --> UC_Predict
Staff --> UC_Result
Staff --> UC_Queue
Staff --> UC_Hist

' --- Médecin ---
Doc --> UC_Login
Doc --> UC_Queue
Doc --> UC_Detail
Doc --> UC_Result
Doc --> UC_Final

' --- Administrateur ---
Admin --> UC_Login
Admin --> UC_MgStaff
Admin --> UC_MgDoc
Admin --> UC_MgPat
Admin --> UC_Stats
Admin --> UC_SysHist

' --- Acteurs techniques ---
UC_Predict --> Api
Api --> ML

' --- Relations entre cas d'utilisation ---
UC_Form ..> UC_Data : <<include>>
UC_Predict ..> UC_Form : <<include>>
UC_Final ..> UC_Result : <<include>>
UC_Validate .> UC_Final : <<extend>>
UC_Rectify .> UC_Final : <<extend>>
UC_Comment .> UC_Final : <<extend>>
@enduml
