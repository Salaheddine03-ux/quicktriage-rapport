@startuml seq_rest
title Scénario 3 : Gestion administrative
skinparam dpi 150
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam sequenceMessageAlign center
skinparam ParticipantBackgroundColor #EAF2F8
skinparam ParticipantBorderColor #1F618D
skinparam ActorBackgroundColor #D6EAF8
skinparam ActorBorderColor #1F618D
skinparam DatabaseBackgroundColor #D5F5E3
skinparam DatabaseBorderColor #1E8449
skinparam SequenceLifeLineBorderColor #5D6D7E
skinparam ArrowColor #2C3E50

actor "Administrateur" as Admin
participant "Interface\nQuickTriage" as UI
participant "UserController" as Ctrl
participant "UserService" as Svc
database "Base de\ndonnées" as DB

Admin -> UI : s'authentifier
activate UI
UI --> Admin : accès autorisé

Admin -> UI : accéder au module d'administration

alt Ajouter un utilisateur
  Admin -> UI : saisir les informations du nouvel utilisateur
  UI -> Ctrl : ajouterUtilisateur(u)
  activate Ctrl
  Ctrl -> Svc : creerUtilisateur(u)
  activate Svc
  Svc -> Svc : valider les informations
  Svc -> DB : INSERT utilisateur
  activate DB
  DB --> Svc : id généré
  deactivate DB
  Svc --> Ctrl : utilisateur créé
  deactivate Svc
  Ctrl --> UI : confirmation
  deactivate Ctrl

else Modifier un utilisateur
  Admin -> UI : modifier les informations
  UI -> Ctrl : modifierUtilisateur(u)
  activate Ctrl
  Ctrl -> Svc : mettreAJourUtilisateur(u)
  activate Svc
  Svc -> Svc : valider les informations
  Svc -> DB : UPDATE utilisateur
  activate DB
  DB --> Svc : confirmation
  deactivate DB
  Svc --> Ctrl : utilisateur mis à jour
  deactivate Svc
  Ctrl --> UI : confirmation
  deactivate Ctrl

else Désactiver / supprimer un utilisateur
  Admin -> UI : supprimer un utilisateur
  UI -> Ctrl : supprimerUtilisateur(id)
  activate Ctrl
  Ctrl -> Svc : supprimerUtilisateur(id)
  activate Svc
  Svc -> DB : DELETE / UPDATE statut
  activate DB
  DB --> Svc : confirmation
  deactivate DB
  Svc --> Ctrl : utilisateur supprimé
  deactivate Svc
  Ctrl --> UI : confirmation
  deactivate Ctrl
end

UI --> Admin : modifications enregistrées

Admin -> UI : consulter les statistiques
UI -> Ctrl : getStatistiques()
activate Ctrl
Ctrl -> Svc : calculerStatistiques()
activate Svc
Svc -> DB : agréger (total patients, cas critiques,\npatients en attente, répartition KTAS)
activate DB
DB --> Svc : indicateurs
deactivate DB
Svc --> Ctrl : statistiques
deactivate Svc
Ctrl --> UI : tableau de bord
deactivate Ctrl
UI --> Admin : afficher les statistiques
deactivate UI
@enduml
